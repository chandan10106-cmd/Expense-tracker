rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isPrimaryAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && (
          request.auth.token.email.lower() == 'chandan10106@gmail.com' ||
          request.auth.token.email.lower() == 'chandan06babu@gmail.com'
        );
    }

    function callerProfile() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : {};
    }

    function isAdmin() {
      return isSignedIn() && (isPrimaryAdmin() || callerProfile().role == 'admin');
    }

    function isApproved() {
      return isSignedIn() && (isPrimaryAdmin() || callerProfile().status == 'approved');
    }

    function isBucketMember(bucketId) {
      return isSignedIn() && (
        isPrimaryAdmin() ||
        (exists(/databases/$(database)/documents/buckets/$(bucketId)) &&
         request.auth.uid in get(/databases/$(database)/documents/buckets/$(bucketId)).data.members)
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && (isPrimaryAdmin()
          || (request.resource.data.status == 'pending'
              && request.resource.data.role == 'member'
              && request.resource.data.isPrimary == false));
      allow update: if isAdmin() && resource.data.get('isPrimary', false) == false;
      allow update: if isPrimaryAdmin() && resource.data.get('isPrimary', false) == false;
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.status == resource.data.status
        && request.resource.data.role == resource.data.role
        && request.resource.data.get('isPrimary', false) == resource.data.get('isPrimary', false);
      allow delete: if isAdmin() && resource.data.get('isPrimary', false) == false;
    }

    match /buckets/{bucketId} {
      allow read: if isApproved();
      allow create, update, delete: if isPrimaryAdmin();
    }

    match /transactions/{txnId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if isAdmin();
    }
  }
}
