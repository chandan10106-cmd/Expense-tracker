rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && (
          request.auth.token.email.lower() == 'chandan10106@gmail.com' ||
          request.auth.token.email.lower() == 'chandan06babu@gmail.com'
        );
    }

    // Proof files - signed-in users can read; only admins can upload/delete
    match /proofs/{userId}/{file=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin()
        && (request.resource == null || request.resource.size < 10 * 1024 * 1024)
        && (request.resource == null
            || request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
    }
  }
}
